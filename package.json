{
  "name": "@defisaver/ui",
  "version": "0.0.1",
  "private": true,
  "description": "DeFi Saver design system — React components styled with StyleX, pre-compiled so consumers need no StyleX tooling.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c && tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist",
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "pack:local": "npm run build && npm pack"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@stylexjs/stylex": "^0.19.0"
  },
  "devDependencies": {
    "@defisaver/eslint-config": "^2.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/react-vite": "^10.4.6",
    "@stylexjs/eslint-plugin": "^0.19.0",
    "@stylexjs/rollup-plugin": "^0.19.0",
    "@stylexjs/unplugin": "^0.19.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.62.2",
    "storybook": "^10.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
